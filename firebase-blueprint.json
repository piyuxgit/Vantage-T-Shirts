{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique identifier from Firebase Auth"
        },
        "displayName": {
          "type": "string",
          "description": "User's full name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "phoneNumber": {
          "type": "string",
          "description": "User's phone number"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Account creation timestamp"
        }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order record",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "UID of the user who placed the order"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "description": "List of items in the order"
        },
        "total": {
          "type": "number",
          "description": "Total order amount"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "shipped", "delivered", "returned"],
          "description": "Current status of the order"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Order placement timestamp"
        }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    }
  }
}
